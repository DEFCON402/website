---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allTalks = (await getCollection('talks')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const latest = allTalks[0];

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Base title="DC402">
  <div class="home">

    <div class="hero">
      <p class="hero-pre">Welcome to the</p>
      <h1 class="hero-title">Omaha <span class="accent">DEF CON</span> Group</h1>
      <p class="hero-sub">Security talks, hacking culture, good people. Every second Tuesday.</p>
    </div>

    {latest && (
      <a href="/slides/" class="card latest-card">
        <div class="latest-label">Latest Talk</div>
        <div class="latest-title">{latest.data.title}</div>
        <div class="latest-meta">
          <span>{latest.data.speaker}</span>
          <span class="dot">·</span>
          <span>{fmtDate(latest.data.date)}</span>
        </div>
        {latest.data.tags && (
          <div class="latest-tags">
            {latest.data.tags.slice(0,3).map(t => (
              <span class="tag">{t}</span>
            ))}
          </div>
        )}
      </a>
    )}

    <div class="card next-card">
      <div class="next-label">Next Talk</div>
      <div class="next-title">How to Make Your Own Website</div>
      <div class="next-meta">
        <span>Mike Kunz</span>
        <span class="dot">·</span>
        <span>August 11, 2026</span>
      </div>
    </div>

    <div class="card meeting-card">
      <div class="meeting-text">
        We meet every <strong>second Tuesday</strong> of the month at a central Omaha venue.
        All skill levels welcome. Come curious.
      </div>
      <a href="/schedule/" class="btn">View Schedule →</a>
    </div>

    <a href="https://goo.gl/forms/CX0CMBDszowuQaak2" class="card speak-card" target="_blank" rel="noopener">
      <div class="speak-text">
        <div class="speak-label">Give a Talk</div>
        <div class="speak-desc">Seasoned infosec veterans and curious beginners are both welcome on stage. A weekend project is enough to get started.</div>
      </div>
      <div class="speak-arrow">Submit a talk →</div>
    </a>

    <div class="quick-links">
      <a href="/schedule/" class="ql-item">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M0 0h24v24H0z" fill="none"/><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
        Schedule
      </a>
      <a href="/slides/" class="ql-item">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M0 0h24v24H0z" fill="none"/><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
        Slides
      </a>
      <a href="/connect/" class="ql-item">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M0 0h24v24H0z" fill="none"/><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
        Connect
      </a>
      <a href="/about/" class="ql-item">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M0 0h24v24H0z" fill="none"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
        About Us
      </a>
      <a href="/sponsor/" class="ql-item">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M0 0h24v24H0z" fill="none"/><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
        Sponsor
      </a>
      <a href="/faq/" class="ql-item">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M0 0h24v24H0z" fill="none"/><path d="M11 18h2v-2h-2v2zm1-16C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-2.21 0-4 1.79-4 4h2c0-1.1.9-2 2-2s2 .9 2 2c0 2-3 1.75-3 5h2c0-2.25 3-2.5 3-5 0-2.21-1.79-4-4-4z"/></svg>
        FAQ
      </a>
    </div>

  </div>
</Base>

<style>
  .home { display: flex; flex-direction: column; gap: 1.5rem; }

  .hero { margin-bottom: 0.5rem; }
  .hero-pre  { font-size: 1rem; color: var(--text-muted); font-weight: 300; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.3rem; }
  .hero-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 900; color: #fff; line-height: 1.1; margin-bottom: 0.6rem; }
  .accent { color: var(--accent); }
  .hero-sub { font-size: 1.05rem; color: var(--text-muted); font-weight: 300; line-height: 1.5; }

  .next-card { display: block; border-color: rgba(255,255,255,0.12); }
  .next-label { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent); margin-bottom: 0.5rem; }
  .next-title { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; line-height: 1.3; }
  .next-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 0.4rem; font-size: 0.8rem; color: var(--text-muted); }

  .latest-card { display: block; text-decoration: none; }
  .latest-label { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent); margin-bottom: 0.5rem; }
  .latest-title { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; line-height: 1.3; }
  .latest-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 0.4rem; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem; }
  .latest-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .dot { color: var(--border); }
  .tag { background: rgba(182,77,77,0.18); color: var(--accent-light); border: 1px solid rgba(182,77,77,0.3); border-radius: 4px; padding: 1px 7px; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.05em; }

  .meeting-card { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .meeting-text { flex: 1; font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; }
  .meeting-text strong { color: var(--text); }

  .btn {
    display: inline-block;
    padding: 0.55rem 1.25rem;
    background: var(--accent);
    color: #fff;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .btn:hover { background: var(--accent-light); color: #fff; }

  .quick-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
  }
  .ql-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.2rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    backdrop-filter: blur(14px);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .ql-item svg { width: 26px; height: 26px; fill: currentColor; }
  .ql-item:hover { color: #fff; border-color: var(--border-accent); background: var(--surface-hover); }

  .speak-card { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; text-decoration: none; border-color: rgba(182,77,77,0.25); }
  .speak-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent); margin-bottom: 0.3rem; }
  .speak-desc { font-size: 0.9rem; color: var(--text-muted); line-height: 1.5; }
  .speak-arrow { font-size: 0.85rem; font-weight: 600; color: var(--accent); white-space: nowrap; flex-shrink: 0; }
  .speak-card:hover .speak-arrow { color: var(--accent-light); }
</style>
