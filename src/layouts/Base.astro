---
interface Props {
  title?: string;
  page?: string;
}
const { title = 'DC402', page = '' } = Astro.props;
const fullTitle = title === 'DC402' ? 'DC402 — Omaha DEF CON Group' : `DC402 — ${title}`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@300;400;500;600&family=Raleway:wght@400;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
</head>
<body>
  <div class="bg-image"></div>

  <div class="site">
    <header>
      <div class="logo-row">
        <a href="/" class="logo-link">
          <span class="logo-primary">defcon</span><span class="logo-secondary">402</span>
        </a>
        <nav class="top-nav">
          <a href="/about/" class="nav-link">
            <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M0 0h24v24H0V0z" fill="none"/><path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/></svg>
            About Us
          </a>
          <a href="/faq/" class="nav-link">
            <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M0 0h24v24H0V0z" fill="none"/><path d="M4 8h4V4H4v4zm6 12h4v-4h-4v4zm-6 0h4v-4H4v4zm0-6h4v-4H4v4zm6 0h4v-4h-4v4zm6-10v4h4V4h-4zm-6 4h4V4h-4v4zm6 6h4v-4h-4v4zm0 6h4v-4h-4v4z"/></svg>
            FAQ
          </a>
          <a href="/sponsor/" class="nav-link">
            <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M0 0h24v24H0V0z" fill="none"/><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9H9V9h10v2zm-4 4H9v-2h6v2zm4-8H9V5h10v2z"/></svg>
            Sponsor
          </a>
          <a href="https://goo.gl/forms/CX0CMBDszowuQaak2" class="nav-link" target="_blank" rel="noopener">
            <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M0 0h24v24H0V0z" fill="none"/><path d="M16 3h-16v14h16l6 6z"/></svg>
            Speak
          </a>
          <a href="https://github.com/DEFCON402/website" class="nav-link" target="_blank" rel="noopener">
            <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M0 0h24v24H0V0z" fill="none"/><path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/></svg>
            Source
          </a>
        </nav>
      </div>
      <nav class="sub-nav">
        <a href="/connect/" class={"sub-nav-link" + (page === "connect" ? " active" : "")}>Connect</a>
        <a href="/schedule/" class={"sub-nav-link" + (page === "schedule" ? " active" : "")}>Schedule</a>
        <a href="/slides/" class={"sub-nav-link" + (page === "slides" ? " active" : "")}>Slides</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>
  </div>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --accent:       #b64d4d;
    --accent-light: #d46464;
    --bg:           #0d0d0e;
    --surface:      rgba(18, 18, 22, 0.72);
    --surface-hover:rgba(28, 28, 34, 0.82);
    --border:       rgba(255,255,255,0.08);
    --border-accent:rgba(182,77,77,0.35);
    --text:         #f0f0f0;
    --text-muted:   rgba(240,240,240,0.52);
    --nav-h:        88px;
    --radius:       12px;
    --font-body:    'Inter', system-ui, sans-serif;
    --font-display: 'Raleway', 'Inter', sans-serif;
    --font-brand:   'Archivo Black', 'Inter', sans-serif;
  }

  html, body { height: 100%; }

  body {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text);
    background: var(--bg);
    overflow-x: hidden;
  }

  a { color: var(--accent); text-decoration: none; transition: color 0.15s; }
  a:hover { color: var(--accent-light); }

  /* ── Background ── */
  .bg-image {
    position: fixed;
    inset: 0;
    background: url('/omaha_bkg.png') no-repeat bottom / 100%;
    background-color: #000;
    z-index: -1;
    opacity: 0.55;
  }

  /* ── Site wrapper ── */
  .site {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* ── Header ── */
  header {
    position: sticky;
    top: 0;
    z-index: 200;
    background: var(--accent);
    flex-shrink: 0;
  }

  .logo-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 52px;
  }

  .logo-link {
    display: flex;
    align-items: baseline;
    gap: 0.18em;
    text-decoration: none;
  }

  .logo-primary {
    font-family: var(--font-brand);
    font-size: 1.9rem;
    font-weight: 700;
    color: #272727;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .logo-secondary {
    font-family: var(--font-brand);
    font-size: 1.55rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
  }

  .top-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0.4rem 0.55rem;
    color: rgba(255,255,255,0.82);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover { color: #fff; background: rgba(255,255,255,0.12); }

  .nav-icon {
    width: 13px;
    height: 13px;
    fill: currentColor;
    flex-shrink: 0;
  }

  .sub-nav {
    display: flex;
    align-items: center;
    background: rgba(0,0,0,0.22);
    padding: 0 2rem;
    height: 36px;
    gap: 0.15rem;
  }

  .sub-nav-link {
    padding: 0.3rem 0.75rem;
    color: rgba(255,255,255,0.65);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
  }
  .sub-nav-link:hover, .sub-nav-link.active { color: #fff; background: rgba(255,255,255,0.1); }

  /* ── Main ── */
  main {
    flex: 1;
    padding: 2.5rem 2rem 3rem;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Glass card ── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    padding: 1.5rem;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: var(--border-accent); }

  /* ── Page heading ── */
  .page-heading {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 1.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ── Scrollbar ── */
  ::-webkit-scrollbar { width: 7px; height: 7px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 4px; }

  @media (max-width: 600px) {
    .logo-row { padding: 0 1rem; }
    .sub-nav  { padding: 0 1rem; }
    main      { padding: 1.5rem 1rem 2rem; }
    .top-nav  { display: none; }
  }
</style>
